				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.data && response.data.session) {",
									"    pm.environment.set(\"auth_token\", response.data.session.access_token);",
									"    pm.test(\"Token berhasil didapatkan dan disimpan ke Environment\", function () {",
									"        pm.expect(response.data.session.access_token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
