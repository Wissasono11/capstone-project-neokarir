		{
			"name": "8. AI Career Assistant (Chatbot)",
			"description": "Endpoint asisten karir AI menggunakan model LLM + RAG (Retrieval Augmented Generation).",
			"item": [
				{
					"name": "List Chats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"url": {
							"raw": "{{api_url}}/chat",
							"host": [
								"{{api_url}}"
							],
							"path": [
								"chat"
							]
						},
						"description": "Mendapatkan daftar sesi percakapan asisten karir user."
					},
					"response": []
				},
				{
					"name": "Create Chat Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.data && response.data.id) {",
									"    pm.environment.set(\"chat_id\", response.data.id);",
									"    pm.test(\"Sesi Chat berhasil dibuat, chat_id disimpan\", function () {",
									"        pm.expect(response.data.id).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
