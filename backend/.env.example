# Server
NODE_ENV=development
PORT=5000

# CORS
CORS_ORIGIN=http://localhost:3001

# Supabase (Database & Auth)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-anon-key>
DATABASE_URL=postgresql://postgres.<your-project-ref>:<your-db-password>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Optional: enable a real query for /health/db by specifying a table name
# DB_HEALTHCHECK_TABLE=users

# AI service integrations
AI_SERVICE_1_URL=http://localhost:8000
AI_SERVICE_2_URL=http://localhost:8001

# Hugging Faces Spaces Configuration
AI_API_KEY=