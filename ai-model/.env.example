# Environment variables for Docker Compose in ai-model directory
# Copy this file to .env and fill in your actual credentials.

# Required for Chatbot / LLM Services (services-1)
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face Spaces Deployment Configuration (Write Access Token)
# Required for running the automated deployer container
HF_TOKEN=your_hugging_face_access_token_here

